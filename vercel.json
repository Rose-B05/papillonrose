{
  "headers": [
    {
      "source": "/products/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/late-alerts",
      "schedule": "0 9 * * *"
    }
  ],
  "buildCommand": "npx next build",
  "installCommand": "npm install",
  "framework": "nextjs"
}

# ─── Stripe (paiement en ligne) ───
# Obtenez vos clés sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_webhook

# ─── Email (Nodemailer) ───
# Pour Gmail : activer "Mots de passe d'application" dans la sécurité du compte
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=contact@papillonrose.fr

# ─── Email de réception (admin) ───
CONTACT_EMAIL=contact@papillonrose.fr

# ─── WhatsApp ───
# Numéro de téléphone WhatsApp (sans le 0 initial, ex: 33612345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=33612345678

# ─── Admin (authentification) ───
# Générer le hash avec : node -e "console.log(require('bcryptjs').hashSync('votre_mdp', 10))"
ADMIN_EMAIL=admin@papillonrose.fr
ADMIN_PASSWORD_HASH=$2a$10$exemple_de_hash_bcrypt
# ─── Site URL (production: https://www.papillonrose.fr) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Vercel KV (Redis) ───
# Créer un store KV dans le dashboard Vercel : Settings > Storage > Create KV
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here

# ─── Google PageSpeed Insights (optionnel) ───
# Clé API optionnelle pour éviter les limites de quota partagé.
# Créer une clé : Google Cloud Console → Activer "PageSpeed Insights API" → Créer une clé
# Sans clé ça fonctionne, mais le quota peut être atteint plus vite si vous cliquez souvent sur "Actualiser".
# GOOGLE_PAGESPEED_API_KEY=your_api_key_here
